# --- Database (Prisma / PostgreSQL) ---
# Railway Postgres reference var in prod. For local dev, either point at a local
# Postgres, or switch the schema datasource to sqlite and use file:./dev.db.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fpm?schema=public"

# --- HTTP server ---
PORT=3000
# Comma-separated web origins allowed by CORS (omit for permissive dev).
CORS_ORIGIN="http://localhost:3001"

# --- Chain subscription (IndexerModule) ---
# Comma-separated RPC http(s) endpoints; primary first, fallbacks after.
RPC_URLS="https://api.devnet.solana.com"
# Optional explicit ws endpoint (defaults to primary with http->ws swapped).
# RPC_WS_URL="wss://api.devnet.solana.com"
# Overrides the compiled-in AMM_PROGRAM_ID from @fpm/shared if needed.
# AMM_PROGRAM_ID="H59qQz8DXzUWWc3L528iTCFL36ozwBhJc4tHzuwL2JuY"
# Turn the live subscriber + backfill on (off by default until the IDL is final).
INDEXER_ENABLED=0
