# --- Database (Prisma / PostgreSQL) ---
# Railway Postgres reference var in prod. Local dev (matches the docker command
# below; port 5433 to avoid clashing with other local Postgres containers):
#   docker run -d --name fpm-postgres -p 5433:5432 \
#     -e POSTGRES_PASSWORD=fpm -e POSTGRES_DB=fpm postgres:16-alpine
# (SQLite fallback: switch the schema datasource to sqlite + file:./dev.db —
# the Prisma schema stays Postgres-authoritative.)
DATABASE_URL="postgresql://postgres:fpm@localhost:5433/fpm?schema=public"

# --- HTTP server ---
PORT=3900
# Comma-separated web origins allowed by CORS (omit for permissive dev).
CORS_ORIGIN="http://localhost:3001"

# --- Chain indexing (IndexerModule) ---
# Preferred keyed endpoint (e.g. Helius). Takes priority over RPC_URLS.
# Never commit real API keys — .env is gitignored.
# HELIUS_RPC_URL="https://devnet.helius-rpc.com/?api-key=..."
# Comma-separated RPC http(s) endpoints; primary first, fallbacks after.
RPC_URLS="https://api.devnet.solana.com"
# Optional explicit ws endpoint (defaults to primary with http->ws swapped).
# RPC_WS_URL="wss://api.devnet.solana.com"
# Overrides the compiled-in AMM_PROGRAM_ID from @fpm/shared if needed.
# AMM_PROGRAM_ID="H59qQz8DXzUWWc3L528iTCFL36ozwBhJc4tHzuwL2JuY"
# Turn the boot backfill + live tail on.
INDEXER_ENABLED=0
# Poll interval for the live signature tail (ms, min 1000).
INDEXER_POLL_MS=15000
