// Prisma schema for the @fpm/indexer service.
//
// Datasource = PostgreSQL (the deployment target — Railway Postgres).
//
// DEV FALLBACK: if Postgres is not reachable locally, switch `provider` to
// "sqlite" and set DATABASE_URL="file:./dev.db". The models below are written
// for Postgres semantics — the `@db.*` native types are Postgres-only and must
// be dropped when running on SQLite (SQLite maps Decimal -> numeric text). The
// generated client API is identical either way.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// One row per on-chain Market PDA. Denormalized snapshot for fast list/detail
/// reads; mirrors the fields the UI needs from the decoded Market account.
model Market {
  id            String   @id // market PDA (base58); Market1x2 PDA for 1X2 rows
  fixtureId     BigInt   @unique @map("fixture_id") // i64 TxLINE fixture id
  configId      String   @map("config_id") // MarketConfig PDA (base58)
  state         String // Open | Trading | Locked | Resolved | Closed

  // Market-kind discriminator (C2): 0 = Binary (v0 YES/NO CPMM, default),
  // 1 = OneXTwo (3-way 1X2 LMSR). Binary columns (yes*/no*) are meaningful only
  // for kind 0; the oneX* columns below only for kind 1. The list query keys the
  // union DTO on this field; existing binary rows default to 0 (back-compat).
  marketKind    Int      @default(0) @map("market_kind")

  outcome       Int? // binary: null until resolved (0 = NO, 1 = YES)

  yesReserve    Decimal  @default(0) @map("yes_reserve") @db.Decimal(40, 0)
  noReserve     Decimal  @default(0) @map("no_reserve") @db.Decimal(40, 0)
  yesSupply     Decimal  @default(0) @map("yes_supply") @db.Decimal(40, 0)
  noSupply      Decimal  @default(0) @map("no_supply") @db.Decimal(40, 0)

  yesPriceBps   Int      @default(5000) @map("yes_price_bps") // 0..10000, mirrors last_price_bps

  // ---- 1X2 (OneXTwo) columns — null/zero for binary rows (marketKind = 0) ---
  // Softmax display prices per outcome (bps); the three sum to ~10_000.
  oneXTeam1PriceBps Int?  @map("onex_team1_price_bps")
  oneXDrawPriceBps  Int?  @map("onex_draw_price_bps")
  oneXTeam2PriceBps Int?  @map("onex_team2_price_bps")
  // Outstanding USER token supply per outcome (u64 base units; excludes seed).
  oneXTeam1Supply   Decimal @default(0) @map("onex_team1_supply") @db.Decimal(40, 0)
  oneXDrawSupply    Decimal @default(0) @map("onex_draw_supply") @db.Decimal(40, 0)
  oneXTeam2Supply   Decimal @default(0) @map("onex_team2_supply") @db.Decimal(40, 0)
  // LMSR liquidity parameter b (u64 base units).
  oneXB             Decimal @default(0) @map("onex_b") @db.Decimal(40, 0)
  // Resolved 1X2 outcome: null (unresolved) | "Team1" | "Draw" | "Team2" | "Void".
  outcome1x2        String? @map("outcome_1x2")

  baseFeeBps    Int?     @map("base_fee_bps")
  currentFeeBps Int?     @map("current_fee_bps") // derived from v_acc if computed

  totalVolume   Decimal  @default(0) @map("total_volume") @db.Decimal(40, 0) // cumulative collateral base units

  homeTeam      String?  @map("home_team") // enrichment from TxLINE fixtures
  awayTeam      String?  @map("away_team")
  competition   String?  @map("competition") // e.g. "World Cup" (TxLINE snapshot)
  competitionId Int?     @map("competition_id")
  kickoffTs     DateTime? @map("kickoff_ts")
  freezeTs      DateTime? @map("freeze_ts")

  // Live-score enrichment from TxLINE scores snapshot (refreshed while Trading;
  // captured once when Locked/Resolved). Null until the score feed has data.
  homeScore     Int?     @map("home_score")
  awayScore     Int?     @map("away_score")
  statusId      Int?     @map("status_id") // TxLINE StatusId (100 = finalised)
  matchClock    String?  @map("match_clock") // human clock, e.g. "77:26"
  gameState     String?  @map("game_state") // TxLINE GameState string

  // Reference market odds from TxLINE demargined StablePrice feed (implied
  // probabilities in basis points). Null until the odds feed returns 1X2.
  oddsHomeBps   Int?     @map("odds_home_bps")
  oddsDrawBps   Int?     @map("odds_draw_bps")
  oddsAwayBps   Int?     @map("odds_away_bps")
  oddsTs        BigInt?  @map("odds_ts") // snapshot ts (ms epoch) of the odds row

  updatedSlot   BigInt   @map("updated_slot")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  pricePoints   PricePoint[]
  volumePoints  VolumePoint[]
  trades        Trade[]
  redemptions   Redemption[]

  @@map("markets")
}

/// Append-only time-series of YES price snapshots for charts.
model PricePoint {
  id          BigInt   @id @default(autoincrement())
  marketId    String   @map("market_id")
  market      Market   @relation(fields: [marketId], references: [id])
  ts          DateTime
  slot        BigInt
  yesPriceBps Int      @map("yes_price_bps")
  yesReserve  Decimal  @map("yes_reserve") @db.Decimal(40, 0)
  noReserve   Decimal  @map("no_reserve") @db.Decimal(40, 0)
  feeBps      Int?     @map("fee_bps")

  @@index([marketId, ts], map: "idx_price_points_market_ts")
  @@map("price_points")
}

/// Append-only time-series of trade volume buckets for charts.
model VolumePoint {
  id       BigInt   @id @default(autoincrement())
  marketId String   @map("market_id")
  market   Market   @relation(fields: [marketId], references: [id])
  ts       DateTime
  slot     BigInt
  volume   Decimal  @db.Decimal(40, 0) // collateral base units in this bucket

  @@index([marketId, ts], map: "idx_volume_points_market_ts")
  @@map("volume_points")
}

/// Individual Buy/Sell events decoded from program logs. Idempotent on
/// (signature, event_index) so replay/backfill never double-inserts.
model Trade {
  id           BigInt   @id @default(autoincrement())
  marketId     String   @map("market_id")
  market       Market   @relation(fields: [marketId], references: [id])
  signature    String
  eventIndex   Int      @map("event_index") // position within the tx
  trader       String
  side         Int // 0 = NO, 1 = YES
  action       String // buy | sell
  usdtIn       Decimal  @map("usdt_in") @db.Decimal(40, 0) // collateral in (buy)
  usdtOut      Decimal  @map("usdt_out") @db.Decimal(40, 0) // collateral out (sell)
  tokensAmount Decimal  @map("tokens_amount") @db.Decimal(40, 0)
  priceBps     Int      @map("price_bps") // YES price after trade
  feeBps       Int      @map("fee_bps")
  ts           DateTime
  slot         BigInt

  @@unique([signature, eventIndex], map: "uq_trades_sig_event")
  @@index([marketId, ts], map: "idx_trades_market_ts")
  @@map("trades")
}

/// Winner payouts decoded from `Redeemed` program events. Idempotent on
/// (signature, event_index) like trades.
model Redemption {
  id         BigInt   @id @default(autoincrement())
  marketId   String   @map("market_id")
  market     Market   @relation(fields: [marketId], references: [id])
  signature  String
  eventIndex Int      @map("event_index")
  owner      String
  outcome    Int // 0 = NO, 1 = YES (the resolved side being redeemed)
  payout     Decimal  @db.Decimal(40, 0) // collateral base units paid out
  ts         DateTime
  slot       BigInt

  @@unique([signature, eventIndex], map: "uq_redemptions_sig_event")
  @@index([marketId, ts], map: "idx_redemptions_market_ts")
  @@map("redemptions")
}

/// Single-row replay checkpoint so the indexer resumes after downtime.
model IndexerCursor {
  id                   Boolean @id @default(true)
  lastIndexedSignature String? @map("last_indexed_signature")
  lastIndexedSlot      BigInt? @map("last_indexed_slot")

  @@map("indexer_cursor")
}
