# --- Solana ---
# Comma-separated RPC http(s) endpoints; primary first, fallbacks after.
# For the demo, add a paid endpoint (Helius/Triton) — public devnet is flaky.
RPC_URLS="https://api.devnet.solana.com"
# Optional explicit ws endpoint (defaults to primary with http->ws swapped).
# RPC_WS_URL="wss://api.devnet.solana.com"
CLUSTER=devnet
# Required to run against mainnet (fat-finger guard).
# ALLOW_MAINNET=1

# Keeper signer (ONE of): base58 secret key, JSON array, or a file path.
# Authorized on-chain ONLY for activate/freeze/resolve — never user funds.
# KEEPER_KEYPAIR="[12,34,...]"
# KEEPER_KEYPAIR="<base58-secret-key>"
# KEEPER_KEYPAIR_PATH="/path/to/keeper.json"

# --- TxLINE ---
TXLINE_BASE_URL="https://txline.txodds.com"
# X-Api-Token from /api/token/activate (guest JWT is fetched at runtime).
# TXLINE_API_TOKEN="<api-token>"

# --- Priority fees ---
PRIORITY_FEE_MODE=dynamic          # dynamic | fixed
PRIORITY_FEE_FIXED_MICROLAMPORTS=1000
PRIORITY_FEE_FLOOR_MICROLAMPORTS=100
PRIORITY_FEE_CEILING_MICROLAMPORTS=1000000

# --- Runtime ---
SCHEDULER_TICK_MS=5000
LOG_LEVEL=info
# Durable retry queue (optional; in-memory fallback without it).
# REDIS_URL="redis://localhost:6379"

# --- Flags ---
# Simulate but never send (structure/dev).
DRY_RUN=1
# Start the SSE score stream (needs TXLINE_API_TOKEN).
ENABLE_SCORE_STREAM=0
