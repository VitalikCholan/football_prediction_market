# --- Solana ---
# Comma-separated RPC http(s) endpoints; primary first, fallbacks after.
# For the demo, add a paid endpoint (Helius/Triton) — public devnet is flaky.
RPC_URLS="https://api.devnet.solana.com"
# Optional explicit ws endpoint (defaults to primary with http->ws swapped).
# RPC_WS_URL="wss://api.devnet.solana.com"
CLUSTER=devnet
# Required to run against mainnet (fat-finger guard).
# ALLOW_MAINNET=1

# Keeper signer (ONE of): base58 secret key, JSON array, or a file path.
# Authorized on-chain ONLY for activate/freeze/resolve — never user funds.
# KEEPER_KEYPAIR="[12,34,...]"
# KEEPER_KEYPAIR="<base58-secret-key>"
# KEEPER_KEYPAIR_PATH="/path/to/keeper.json"

# --- TxLINE ---
# Two origins exist; devnet is the default (60s-delayed data, hackathon track):
#   devnet : https://txline-dev.txodds.com
#   mainnet: https://txline.txodds.com
TXLINE_BASE_URL="https://txline-dev.txodds.com"
# X-Api-Token from /api/token/activate (guest JWT is fetched at runtime).
# TXLINE_API_TOKEN="<api-token>"

# --- Priority fees ---
PRIORITY_FEE_MODE=dynamic          # dynamic | fixed
PRIORITY_FEE_FIXED_MICROLAMPORTS=1000
PRIORITY_FEE_FLOOR_MICROLAMPORTS=100
PRIORITY_FEE_CEILING_MICROLAMPORTS=1000000

# --- Runtime ---
SCHEDULER_TICK_MS=5000
LOG_LEVEL=info
# Durable retry queue (optional; in-memory fallback without it).
# REDIS_URL="redis://localhost:6379"

# --- Flags ---
# Simulate but never send (structure/dev).
DRY_RUN=1
# Start the SSE score stream (needs TXLINE_API_TOKEN).
ENABLE_SCORE_STREAM=0

# --- Mark poster (opt-in, v1 leverage) ---
# Post post_mark for every Trading market that has a LeveragePool PDA, at each
# market config's funding_epoch_secs cadence (checked against pool.mark_ts, so
# restarts self-heal). Marks come from the TxLINE StablePrice 1X2 odds snapshot
# when available, else from the on-chain LMSR spot prices (the normal devnet
# case — the WC odds feed returns []). OFF by default; requires the keeper
# signer == GlobalConfig.keeper (post_mark is keeper-gated on-chain).
ENABLE_MARK_POSTER=0

# --- Auto-seed (opt-in) ---
# Periodically poll TxLINE fixtures/snapshot and init_market for strictly-future
# fixtures that have no Market PDA yet, so upcoming markets self-appear on-chain
# while the keeper runs. OFF by default — init_market spends SOL (account rent)
# and USDT seed liquidity, so it must be opt-in. Requires TXLINE_API_TOKEN and
# the keeper signer == GlobalConfig.authority (the seeder refuses to send if not).
ENABLE_AUTO_SEED=0
# How often the auto-seed loop runs (ms). Default 3600000 = hourly (the fixtures
# feed refreshes ~hourly; more often just wastes RPC).
AUTO_SEED_INTERVAL_MS=3600000
# Hard per-run cap on how many new markets to seed (SOL-drain guard). Default 5.
MAX_SEED_PER_RUN=5
# List what auto-seed WOULD create each run and send NOTHING (verify safely).
AUTO_SEED_DRY_RUN=0

# --- Smoke mode (pnpm smoke / SMOKE=1) ---
# Devnet wiring check against the LIVE program; simulate-only, never sends.
# Defaults: Helius devnet RPC + public fallback, ~/.config/solana/id.json.
# SMOKE=1
# Narrow the market listing to known fixture id(s), comma-separated.
# SMOKE_FIXTURE_ID=17588316

# --- TxLINE API smoke (pnpm smoke:txline / SMOKE_TXLINE=1) ---
# Proves the keeper's TxLINE parsers against the LIVE API (read-only, no
# Solana): live SSE parse, historical replay + match-end detection, and a real
# stat-validation proof mapped to ResolveProofArgs. Needs TXLINE_API_TOKEN.
# How long to listen on the live SSE stream (default 30).
# SMOKE_SSE_SECONDS=30

# --- Auto-seed dry-run smoke (pnpm --filter @fpm/keeper smoke:seed / SMOKE_SEED=1) ---
# Runs ONE auto-seed pass with AUTO_SEED_DRY_RUN forced: lists the fixtures it
# WOULD init_market (ids, teams, reserves, prob source) against the LIVE program
# + LIVE TxLINE API and sends NOTHING. Needs TXLINE_API_TOKEN.
# SMOKE_SEED=1
