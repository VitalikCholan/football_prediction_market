{
  "name": "@fpm/keeper",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --experimental-transform-types --import ./hooks/register.mjs src/index.ts",
    "start": "node --experimental-transform-types --import ./hooks/register.mjs src/index.ts",
    "smoke": "node --experimental-transform-types --import ./hooks/register.mjs src/index.ts --smoke",
    "smoke:txline": "node --env-file-if-exists=.env --experimental-transform-types --import ./hooks/register.mjs src/index.ts --smoke-txline",
    "smoke:seed": "node --env-file-if-exists=.env --experimental-transform-types --import ./hooks/register.mjs src/index.ts --smoke-seed",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fpm/idl": "workspace:*",
    "@fpm/shared": "workspace:*",
    "@solana-program/compute-budget": "^0.9",
    "@solana/kit": "^2",
    "pino": "^9",
    "undici": "^7",
    "zod": "^3"
  },
  "devDependencies": {
    "@fpm/tsconfig": "workspace:*",
    "@types/node": "^24"
  }
}
